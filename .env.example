# DeepSeek API key (required)
api_key=sk-your-deepseek-api-key

# API base URL
base_url=https://api.deepseek.com

# Model name
model=deepseek-v4-pro

# Server port
port=11435

# Upstream API timeout in minutes (default: 30)
timeout=30

# Set to false if the target model is not a DeepSeek model
is_deepseek=true

# Multimodal support: set to true if your model supports image inputs
multimodal=false
